{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/douxy1994/Pythia/schemas/sync-metadata.schema.json",
  "title": "PythiaSyncMetadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "appVersion", "updatedAt", "devices"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "appVersion": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["deviceId", "platform", "lastSyncAt"],
        "properties": {
          "deviceId": {
            "type": "string",
            "minLength": 1
          },
          "platform": {
            "type": "string",
            "enum": ["macOS", "Windows"]
          },
          "displayName": {
            "type": ["string", "null"]
          },
          "lastSyncAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
