{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/douxy1994/Pythia/schemas/history-collection.schema.json",
  "title": "PythiaHistoryCollection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "updatedAt", "deviceId", "records"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "deviceId": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "history-record.schema.json"
      }
    }
  }
}
